{
  "$schema": "https://json.schemastore.org/package",
  "name": "@gingacodemonkey/config",
  "description": "A collection of TypeScript configurations, based on Total TypeScript's TSConfig Cheat Sheet. ESLint rules based on @epic-web/config.",
  "version": "0.0.38",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "start": "rollup --watch --config rollup.config.ts --configPlugin @rollup/plugin-typescript ",
    "build": "node build.ts && pnpm pack",
    "rc": "pnpm version prerelease --preid=rc --no-git-tag-version && pnpm build",
    "build:bump": "node build.ts && pnpm version patch --no-git-tag-version && pnpm pack",
    "build:bump-dev": "node build.ts && pnpm version prerelease --no-git-tag-version && pnpm pack",
    "prepare": "husky",
    "test": "pnpm --filter @gingacodemonkey/config-tests test",
    "test:watch": "pnpm --filter @gingacodemonkey/config-tests test:watch",
    "test:docker": "docker compose up --build --abort-on-container-exit",
    "lint:ts": "tsc --noEmit",
    "lint:esl": "eslint --config eslint.config.ts \"{tests,src}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:s": "eslint --config eslint.config.style.ts \"{tests,src}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:fix": "pnpm lint:s --fix",
    "lint": "pnpm lint:ts && pnpm lint:esl && pnpm lint:fix",
    "lint:esl:fix": "pnpm lint:esl --fix",
    "lint:knip": "knip",
    "lint:jscpd": "jscpd .",
    "lint:e18e": "pnpm dlx @e18e/cli analyze"
  },
  "main": "dist/setup.cjs",
  "bin": {
    "gingacodemonkey-config": "dist/setup.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianbrowning/config.git"
  },
  "homepage": "https://github.com/adrianbrowning/config.git",
  "author": "Adrian Elton-Browning",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    "./tsc/dom/app": "./tsc/tsc/dom/app.json",
    "./tsc/dom/library": "./tsc/tsc/dom/library.json",
    "./tsc/dom/library-monorepo": "./tsc/tsc/dom/library-monorepo.json",
    "./tsc/no-dom/app": "./tsc/tsc/no-dom/app.json",
    "./tsc/no-dom/library": "./tsc/tsc/no-dom/library.json",
    "./tsc/no-dom/library-monorepo": "./tsc/tsc/no-dom/library-monorepo.json",
    "./bundler/dom/app": "./tsc/bundler/dom/app.json",
    "./bundler/dom/library": "./tsc/bundler/dom/library.json",
    "./bundler/dom/library-monorepo": "./tsc/bundler/dom/library-monorepo.json",
    "./bundler/no-dom/app": "./tsc/bundler/no-dom/app.json",
    "./bundler/no-dom/library": "./tsc/bundler/no-dom/library.json",
    "./bundler/no-dom/library-monorepo": "./tsc/bundler/no-dom/library-monorepo.json",
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    },
    "./styled": {
      "types": "./dist/eslint.styled.d.ts",
      "default": "./dist/eslint.styled.js"
    },
    "./eslint.ts": "./dist/eslint.js",
    "./styled.ts": "./dist/eslint.styled.js"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.14.8",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@eslint/json": "^2.0.1",
    "@listr2/prompt-adapter-enquirer": "^3.0.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@typescript-eslint/utils": "^8.64.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "enquirer": "^2.4.1",
    "eslint": "^9.39.5",
    "eslint-plugin-big-o": "^1.1.1",
    "eslint-plugin-de-morgan": "^2.1.3",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "eslint-plugin-security-node": "^1.1.4",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "listr2": "^9.0.5",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.64.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "json5": "^2.2.3",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "react": "^19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "eslint": "^9.39.5",
    "husky": "9.1.7",
    "jscpd": "^5.0.12",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "tsc",
    "eslint.js",
    "eslint.styled.js"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
